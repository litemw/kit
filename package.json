{
  "name": "@litemw/kit",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:js && bun run build:dts",
    "build:dts": "tsc -p tsconfig.build.json",
    "build:js": "bun build lib/index.ts --outfile dist/index.js --target node --format esm --packages external",
    "clean": "rimraf dist",
    "lint": "eslint . --cache --no-warn-ignored",
    "lint:fix": "bun run lint --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@litemw/iocc": "^0.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@litemw/iocc": "^0.0.7",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@logtape/logtape": "^2.2.4"
  }
}
